direction: down

title: {
  label: Rubik's Cube Timer — Module Dependencies
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# Entry point
main.js: main.js\n(Entry Point) {
  style.fill: "#fef3c7"
  style.bold: true
}

# Core modules
state.js: state.js\n(Constants, DIRECTION_INDEX,\nTRANSLATION_MATRIX) {
  style.fill: "#dbeafe"
}

storage.js: storage.js\n(State CRUD,\ngetActiveSolves) {
  style.fill: "#dbeafe"
}

utils.js: utils.js\n(formatTime, createId,\napplyPenalty, validateScramble) {
  style.fill: "#dbeafe"
}

# Cube rendering
cube.js: cube.js\n(Cube rendering,\nThree.js bridge) {
  style.fill: "#dcfce7"
}

ThreeCube.js: ThreeCube.js\n(Three.js 3D impl) {
  style.fill: "#dcfce7"
}

dynamic-cube.js: dynamic-cube.js\n(Logical cube state,\nmove application) {
  style.fill: "#dcfce7"
}

preview.js: preview.js\n(2D net preview) {
  style.fill: "#dcfce7"
}

# Gameplay
scramble.js: scramble.js\n(Scramble generation) {
  style.fill: "#f3e8ff"
}

cubes.js: cubes.js\n(Cube configs 2x2–7x7) {
  style.fill: "#f3e8ff"
}

timer.js: timer.js\n(Timer + inspection) {
  style.fill: "#f3e8ff"
}

input.js: input.js\n(Keyboard handler) {
  style.fill: "#f3e8ff"
}

solver.js: solver.js\n(WASM solver) {
  style.fill: "#f3e8ff"
}

solver-loader.js: solver-loader.js\n(WASM module loader) {
  style.fill: "#f3e8ff"
}

# Data display
stats.js: stats.js\n(Statistics computation) {
  style.fill: "#fce7f3"
}

charts.js: charts.js\n(Chart.js integration) {
  style.fill: "#fce7f3"
}

history.js: history.js\n(Solve list UI) {
  style.fill: "#fce7f3"
}

sessions.js: sessions.js\n(Session CRUD UI) {
  style.fill: "#fce7f3"
}

# UI & features
panels.js: panels.js\n(Panel interactions) {
  style.fill: "#f1f5f9"
}

settings.js: settings.js\n(Settings UI) {
  style.fill: "#f1f5f9"
}

io.js: io.js\n(Import / Export) {
  style.fill: "#f1f5f9"
}

leaderboard.js: leaderboard.js\n(Leaderboard UI) {
  style.fill: "#f1f5f9"
}

tutorial.js: tutorial.js\n(Interactive lessons) {
  style.fill: "#f1f5f9"
}

onboarding.js: onboarding.js\n(First-time walkthrough) {
  style.fill: "#f1f5f9"
}

sound.js: sound.js\n(Web Audio tones) {
  style.fill: "#f1f5f9"
}

pwa.js: pwa.js\n(Service Worker) {
  style.fill: "#f1f5f9"
}

