{
  "name": "rubiks-cube",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.{md,json}\"",
    "build:wasm": "emcc src/wasm/solver.cpp -O3 -sENVIRONMENT=web -sEXPORT_ES6=1 -sMODULARIZE=1 -sEXPORTED_FUNCTIONS=['_validate_scramble','_get_hint'] -sEXPORTED_RUNTIME_METHODS=['cwrap'] -o src/wasm/solver.js"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "vite": "^8.0.10"
  }
}
